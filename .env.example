# Google Drive API key (get from https://console.cloud.google.com)
VITE_GOOGLE_API_KEY=your_api_key_here

# Google Drive root folder ID (the folder containing your book subfolders)
# Find it in the URL when viewing the folder: https://drive.google.com/drive/folders/THIS_PART
VITE_DRIVE_FOLDER_ID=your_folder_id_here
