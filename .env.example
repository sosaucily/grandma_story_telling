# Server-side only (used by Vercel serverless functions)
# These are NOT exposed to the browser.

# Google Drive API key (get from https://console.cloud.google.com)
GOOGLE_API_KEY=your_api_key_here

# Google Drive root folder ID (the folder containing your book subfolders)
# Find it in the URL when viewing the folder: https://drive.google.com/drive/folders/THIS_PART
DRIVE_FOLDER_ID=your_folder_id_here

# Upstash Redis (for session sync between Grandma and Eli)
# Get these from https://console.upstash.com after creating a Redis database
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
